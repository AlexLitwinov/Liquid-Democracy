# R session artifacts
.Rproj.user
.Rhistory
.RData
.Ruserdata

# renv library (packages are restored via renv::restore(), not committed)
renv/library/
renv/local/
renv/cellar/
renv/lock/
renv/python/
renv/sandbox/
renv/staging/

# Simulation output — binary data files and knitr figures (regenerated by re-running simulations)
simulations/output/*.rds
simulations/output/figures/

# Auto-generated simulation notebook output (source .Rmd is tracked, not the rendered .md)
simulations/*.md

# knitr cache
*_cache/
chunk_outputs/
